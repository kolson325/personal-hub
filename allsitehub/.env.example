SITEFOTOS_API_KEY=put_your_key_here
SITEFOTOS_ACCESS_CODE=put_access_code_here_if_required
SITEFOTOS_API_BASE_URL=https://www.sitefotos.com
SITEFOTOS_API_BEARER=true

# Optional: rate-limit public updates (default 60s).
UPDATE_MIN_INTERVAL_SECONDS=60

# Hard kill a stuck updater after N seconds (default 180).
UPDATE_MAX_SECONDS=180

# Optional: if SiteFotos uses a different access-code mechanism:
# SITEFOTOS_ACCESS_CODE_HEADER=X-Access-Code
# SITEFOTOS_ACCESS_CODE_QUERY_PARAM=access_code
# SITEFOTOS_SEND_ACCESS_CODE_HEADER=true
# SITEFOTOS_SEND_ACCESS_CODE_QUERY=false

# Optional: override "today" for debugging (YYYY-MM-DD)
# DASHBOARD_TODAY=
