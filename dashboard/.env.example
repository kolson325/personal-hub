DATABASE_URL="file:./db/dev.db"

# Set this to a long random string; required for login.
DASHBOARD_PASSWORD=""

# Token used by the local companion to poll/report jobs.
AGENT_TOKEN=""

# Dashboard base URL the companion connects to (local dev or VPS).
DASHBOARD_URL="http://localhost:3000"

# Optional: used by the local companion to identify itself.
AGENT_ID="kolson-mac"

# Optional: where THE-COMBINE repo lives on your local machine (only used by the local companion).
COMBINE_REPO_PATH=""

# Optional: default working directory for Codex jobs (LOCAL runner).
CODEX_CWD=""

# Optional: Codex sandbox for LOCAL runs: "read-only" or "workspace-write".
CODEX_SANDBOX="workspace-write"

# Where the Allsite Central Hub lives (external URL or VPS host). Used for the Central Hub panel + embed.
ALLSITE_CENTRAL_HUB_URL="https://allsitefacilities-centralhub.loca.lt"
