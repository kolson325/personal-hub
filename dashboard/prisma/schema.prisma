generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TodoStatus {
  OPEN
  DONE
}

enum JobStatus {
  QUEUED
  CLAIMED
  SUCCEEDED
  FAILED
  CANCELED
}

model TodoItem {
  id        String     @id @default(cuid())
  title     String
  notes     String?
  status    TodoStatus @default(OPEN)
  source    String?    // e.g. "manual", "gmail"
  sourceRef String?    // e.g. message id
  pinned    Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  doneAt    DateTime?
}

model AgentRun {
  id             String   @id @default(cuid())
  agentType      String   // "bizdev", "devops"
  status         String   // "running", "succeeded", "failed"
  inputJson      String?
  outputMarkdown String?
  error          String?
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
}

model AgentJob {
  id          String    @id @default(cuid())
  kind        String    // e.g. "shell"
  payloadJson String
  status      JobStatus @default(QUEUED)
  claimedBy   String?
  createdAt   DateTime  @default(now())
  claimedAt   DateTime?
  finishedAt  DateTime?
  resultText  String?
  errorText   String?
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
