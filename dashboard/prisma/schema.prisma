generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TodoStatus {
  OPEN
  DONE
}

enum JobStatus {
  QUEUED
  CLAIMED
  SUCCEEDED
  FAILED
  CANCELED
}

enum JobRunner {
  VPS
  LOCAL
}

model AgentHeartbeat {
  id         String    @id @default(cuid())
  agentId    String
  runner     JobRunner @default(LOCAL)
  lastSeenAt DateTime  @default(now())

  @@unique([agentId, runner])
}

model PanelLayout {
  id        String   @id
  orderJson String
  updatedAt DateTime @updatedAt
}

enum ScheduleType {
  INTERVAL
  DAILY
  WEEKLY
}

model TodoItem {
  id        String     @id @default(cuid())
  title     String
  notes     String?
  status    TodoStatus @default(OPEN)
  source    String?    // e.g. "manual", "gmail"
  sourceRef String?    // e.g. message id
  pinned    Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  doneAt    DateTime?
}

model AgentRun {
  id             String   @id @default(cuid())
  agentType      String   // "bizdev", "devops"
  status         String   // "running", "succeeded", "failed"
  inputJson      String?
  outputMarkdown String?
  error          String?
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
}

model AgentJob {
  id          String    @id @default(cuid())
  kind        String    // e.g. "shell"
  payloadJson String
  status      JobStatus @default(QUEUED)
  runner      JobRunner @default(VPS)
  claimedBy   String?
  createdAt   DateTime  @default(now())
  claimedAt   DateTime?
  finishedAt  DateTime?
  resultText  String?
  errorText   String?

  scheduleId String?
  schedule   AutomationSchedule? @relation(fields: [scheduleId], references: [id])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AutomationSchedule {
  id              String       @id @default(cuid())
  key             String       // e.g. "bizdev_digest", "devops_radar", "allsite_update"
  name            String
  enabled         Boolean      @default(true)
  scheduleType    ScheduleType @default(INTERVAL)
  intervalMinutes Int?
  timeOfDay       String?      // "HH:MM" (local time in the container)
  daysOfWeek      String?      // "0,1,2" (0=Sun..6=Sat) for WEEKLY
  configJson      String?
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  jobs AgentJob[]
}

model BudgetEntry {
  id          String   @id @default(cuid())
  occurredOn  DateTime @default(now())
  amountCents Int      // positive for income, negative for expense
  category    String?
  merchant    String?
  notes       String?
  createdAt   DateTime @default(now())
}
