# Used by Caddy for ACME/Let's Encrypt registration emails
CADDY_EMAIL="you@example.com"

# Public hostnames
DASHBOARD_HOST="dash.yourdomain.com"
ALLSITE_HUB_HOST="allsite.yourdomain.com"

# Where the Allsite Central Hub is reachable from the dashboard.
# Set this to "https://allsite.<VPS_IP>.nip.io" once the Allsite hub is moved onto the VPS.
ALLSITE_CENTRAL_HUB_URL="https://allsitefacilities-centralhub.loca.lt"

# Secrets
DASHBOARD_PASSWORD="change-this-to-a-long-random-string"
AGENT_TOKEN="change-this-to-a-long-random-string"

# Protect Allsite hub /api/update endpoint
ALLSITEHUB_ADMIN_TOKEN="change-this-to-a-long-random-string"
