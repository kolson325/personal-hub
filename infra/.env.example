# Used by Caddy for ACME/Let's Encrypt registration emails
CADDY_EMAIL="you@example.com"

# Container timezone (affects automation schedules)
TZ="America/New_York"

# Public hostnames
DASHBOARD_HOST="dash.yourdomain.com"
ALLSITE_HUB_HOST="allsite.yourdomain.com"

# Dashboard reverse proxy upstream for Caddy:
# - Default (VPS-hosted dashboard container): "dashboard:3000"
# - Laptop-local dashboard mode over SSH reverse tunnel: "host.docker.internal:7000"
DASHBOARD_UPSTREAM="dashboard:3000"

# Where the Allsite Central Hub is reachable from the dashboard.
# Set this to "https://allsite.<VPS_IP>.nip.io" once the Allsite hub is moved onto the VPS.
ALLSITE_CENTRAL_HUB_URL="https://allsitefacilities-centralhub.loca.lt"

# Secrets
DASHBOARD_PASSWORD="change-this-to-a-long-random-string"
AGENT_TOKEN="change-this-to-a-long-random-string"

# Public update rate limit (seconds)
UPDATE_MIN_INTERVAL_SECONDS=60
UPDATE_MAX_SECONDS=600

# SiteFotos creds for the Allsite hub updater
SITEFOTOS_API_KEY=""
SITEFOTOS_ACCESS_CODE=""
SITEFOTOS_API_BASE_URL="https://www.sitefotos.com"
SITEFOTOS_API_BEARER=true

# Allsite hub updater tuning
SUBMISSION_DETAIL_LIMIT=25
SUBMISSION_DETAIL_SLEEP_MS=75
ENABLE_IMAGE_HEAD_CHECKS=false

# Allsite tracking calendar (custom)
TRACKING_START_DATE="2026-04-01"
TRACKING_WEEK1_END_DATE="2026-04-10"
